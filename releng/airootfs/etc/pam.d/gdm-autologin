#%PAM-1.0
# ClariceOS live ISO — GDM autologin PAM stack.
#
# The stock Arch gdm-autologin includes pam_nologin.so as requisite in both
# the auth and account phases. On a live ISO, GDM may start before
# systemd-user-sessions.service removes /run/nologin, blocking autologin.
#
# Fix: replace "account include system-local-login" (which pulls in
# pam_nologin.so via system-login) with pam_permit.so for the live user.
# The systemd drop-in (gdm.service.d/autologin.conf) also orders GDM after
# systemd-user-sessions.service as a second layer of defence.

auth     required  pam_succeed_if.so user != root quiet
auth     required  pam_permit.so

account  required  pam_permit.so

password required  pam_deny.so

session  optional  pam_keyinit.so force revoke
session  required  pam_limits.so
session  required  pam_env.so
session  required  pam_unix.so
