#!/usr/bin/env bash
# ClariceOS Welcome — First-boot setup assistant
# Runs once on first login after installation.
# Requires: yad (installed via packages.x86_64)

SENTINEL="${HOME}/.config/clariceos/.welcome-done"
TITLE="ClariceOS — Bem-vindo"
ICON_INFO="dialog-information"
ICON_WARN="dialog-warning"
ICON_OK="dialog-ok"

# Do not run inside the live ISO — check both the archiso kernel cmdline marker
# and the sentinel file (belt-and-suspenders: sentinel may not exist if home
# directory setup was interrupted, but the cmdline check is always reliable).
grep -q 'archisolabel\|archiso_label\|cow_spacesize' /proc/cmdline 2>/dev/null && exit 0

# Only run once
[ -f "${SENTINEL}" ] && exit 0

# Require yad and a display
command -v yad &>/dev/null || exit 0
[ -z "${DISPLAY}${WAYLAND_DISPLAY}" ] && exit 0

mkdir -p "${HOME}/.config/clariceos"

# ── Helper: open terminal with a command ─────────────────────────────────────
open_terminal() {
    local cmd="$1"
    local full_cmd="${cmd}; echo; echo '==> Concluído. Pressione Enter para fechar.'; read"
    if command -v gnome-terminal &>/dev/null; then
        gnome-terminal -- bash -c "${full_cmd}"
    elif command -v konsole &>/dev/null; then
        konsole -e bash -c "${full_cmd}"
    elif command -v xterm &>/dev/null; then
        xterm -e bash -c "${full_cmd}"
    fi
}

# ── Step 1: Welcome ───────────────────────────────────────────────────────────
yad --center --title="${TITLE}" \
    --width=600 --height=340 \
    --text="<span size='x-large' weight='bold'>Bem-vindo ao ClariceOS!</span>\n\n\
Seu sistema foi instalado com sucesso.\n\n\
Este assistente vai ajudar você a configurar\n\
o sistema em alguns passos rápidos.\n\n\
<span size='small' color='#6272a4'>Baseado em Arch Linux  •  Tema Dracula  •  Limine Bootloader\n\
PipeWire  •  Flatpak  •  zRAM  •  AppArmor</span>" \
    --button="Começar:0" \
    --button="Pular Tudo:1" \
    || { touch "${SENTINEL}"; exit 0; }

[ $? -eq 1 ] && { touch "${SENTINEL}"; exit 0; }

# ── Step 2: Flathub ──────────────────────────────────────────────────────────
if ! flatpak remotes 2>/dev/null | grep -q "flathub"; then
    yad --center --title="${TITLE}" \
        --width=520 --height=220 \
        --image="${ICON_INFO}" \
        --text="<b>Ativar Flathub?</b>\n\n\
O Flathub é a maior loja de aplicativos Flatpak.\n\
Habilitar permite instalar apps isolados e seguros\n\
como Spotify, Discord, Signal e muito mais." \
        --button="Ativar Flathub:0" \
        --button="Pular:1"

    if [ $? -eq 0 ]; then
        flatpak remote-add --if-not-exists flathub \
            https://dl.flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true
    fi
fi

# ── Step 3: System update ─────────────────────────────────────────────────────
yad --center --title="${TITLE}" \
    --width=520 --height=220 \
    --image="${ICON_INFO}" \
    --text="<b>Atualizar o sistema?</b>\n\n\
Recomendamos atualizar todos os pacotes para a versão\n\
mais recente antes de começar a usar o sistema.\n\n\
<span size='small' color='#6272a4'>Este passo pode demorar alguns minutos.</span>" \
    --button="Atualizar Agora:0" \
    --button="Pular:1"

[ $? -eq 0 ] && open_terminal "yay -Syu --noconfirm"

# ── Step 4: GPU driver detection ─────────────────────────────────────────────
GPU_VENDOR=""
if lspci 2>/dev/null | grep -qi "NVIDIA"; then
    GPU_VENDOR="nvidia"
elif lspci 2>/dev/null | grep -qi "AMD.*VGA\|VGA.*AMD\|ATI.*VGA\|VGA.*ATI\|Advanced Micro Devices.*VGA"; then
    GPU_VENDOR="amd"
elif lspci 2>/dev/null | grep -qi "Intel.*Graphics\|Intel.*VGA\|Intel.*Display"; then
    GPU_VENDOR="intel"
fi

if [ "${GPU_VENDOR}" = "nvidia" ]; then
    if ! pacman -Q nvidia-dkms &>/dev/null 2>&1; then
        yad --center --title="${TITLE}" \
            --width=560 --height=280 \
            --image="${ICON_WARN}" \
            --text="<b>GPU NVIDIA detectada!</b>\n\n\
O driver <tt>nvidia-dkms</tt> não está instalado.\n\n\
• Sem driver: sem aceleração 3D, Wayland instável, sem CUDA\n\
• Com driver: performance completa, Gaming, CUDA, Wayland\n\n\
<span size='small' color='#6272a4'>Pacotes: nvidia-dkms nvidia-utils nvidia-settings\n\
lib32-nvidia-utils — é necessária conexão à internet.</span>" \
            --button="Instalar Driver NVIDIA:0" \
            --button="Pular:1"

        [ $? -eq 0 ] && open_terminal \
            "yay -S --noconfirm --needed nvidia-dkms nvidia-utils nvidia-settings \
             lib32-nvidia-utils && \
             echo 'options nvidia-drm modeset=1 fbdev=1' | \
             sudo tee /etc/modprobe.d/nvidia-drm.conf && \
             echo 'Driver instalado! Reinicie o sistema para ativar.'"
    fi

elif [ "${GPU_VENDOR}" = "amd" ]; then
    if ! pacman -Q vulkan-radeon &>/dev/null 2>&1; then
        yad --center --title="${TITLE}" \
            --width=560 --height=260 \
            --image="${ICON_INFO}" \
            --text="<b>GPU AMD detectada!</b>\n\n\
Recomendamos instalar o driver Vulkan completo para\n\
melhor performance em jogos e Wayland.\n\n\
<span size='small' color='#6272a4'>Pacotes: mesa vulkan-radeon lib32-mesa lib32-vulkan-radeon\n\
libva-mesa-driver — aceleração de vídeo por hardware.</span>" \
            --button="Instalar Driver AMD:0" \
            --button="Pular:1"

        [ $? -eq 0 ] && open_terminal \
            "sudo pacman -S --noconfirm --needed mesa vulkan-radeon lib32-mesa \
             lib32-vulkan-radeon libva-mesa-driver mesa-vdpau && \
             echo 'Driver AMD instalado!'"
    fi

elif [ "${GPU_VENDOR}" = "intel" ]; then
    if ! pacman -Q vulkan-intel &>/dev/null 2>&1; then
        yad --center --title="${TITLE}" \
            --width=560 --height=260 \
            --image="${ICON_INFO}" \
            --text="<b>GPU Intel detectada!</b>\n\n\
Recomendamos instalar o driver Vulkan e o decodificador\n\
de vídeo por hardware para melhor performance.\n\n\
<span size='small' color='#6272a4'>Pacotes: vulkan-intel intel-media-driver\n\
libva-intel-driver — aceleração de vídeo por hardware.</span>" \
            --button="Instalar Driver Intel:0" \
            --button="Pular:1"

        [ $? -eq 0 ] && open_terminal \
            "sudo pacman -S --noconfirm --needed vulkan-intel intel-media-driver \
             libva-intel-driver lib32-vulkan-intel && \
             echo 'Driver Intel instalado!'"
    fi
fi

# ── Step 5: Bluetooth ─────────────────────────────────────────────────────────
if rfkill list bluetooth 2>/dev/null | grep -q "bluetooth" || \
   lsusb 2>/dev/null | grep -qi "bluetooth"; then
    BT_ENABLED=$(systemctl is-enabled bluetooth 2>/dev/null || echo "disabled")
    if [ "${BT_ENABLED}" != "enabled" ]; then
        yad --center --title="${TITLE}" \
            --width=500 --height=220 \
            --image="${ICON_INFO}" \
            --text="<b>Bluetooth detectado!</b>\n\n\
O serviço Bluetooth não está ativo.\n\
Ativar agora para gerenciar fones, teclados\n\
e outros dispositivos sem fio." \
            --button="Ativar Bluetooth:0" \
            --button="Pular:1"

        [ $? -eq 0 ] && sudo systemctl enable --now bluetooth
    fi
fi

# ── Step 6: Printing (CUPS) ───────────────────────────────────────────────────
if lsusb 2>/dev/null | grep -qi "printer\|canon\|epson\|hp\|brother\|lexmark"; then
    CPS_ENABLED=$(systemctl is-enabled cups 2>/dev/null || echo "disabled")
    if [ "${CPS_ENABLED}" != "enabled" ]; then
        yad --center --title="${TITLE}" \
            --width=500 --height=200 \
            --image="${ICON_INFO}" \
            --text="<b>Impressora detectada!</b>\n\n\
O serviço CUPS não está ativo.\n\
Ativar para usar impressoras locais e em rede." \
            --button="Ativar Impressão:0" \
            --button="Pular:1"

        [ $? -eq 0 ] && sudo systemctl enable --now cups
    fi
fi

# ── Step 7: Gaming profile ────────────────────────────────────────────────────
yad --center --title="${TITLE} — Gaming" \
    --width=600 --height=320 \
    --image="${ICON_INFO}" \
    --text="<b>Instalar perfil de Gaming?</b>\n\n\
Inclui tudo para jogar no Linux:\n\
• <tt>steam</tt> — plataforma de jogos\n\
• <tt>proton-ge-custom</tt> — Proton com maior compatibilidade (Chaotic-AUR)\n\
• <tt>mangohud</tt> — overlay de FPS, CPU, RAM, temperatura\n\
• <tt>gamemode</tt> — otimização automática de CPU/GPU durante jogos\n\
• <tt>lutris</tt> — launcher para Epic, GOG, Battle.net, etc.\n\
• <tt>lib32-*</tt> — suporte a jogos 32-bit\n\n\
<span size='small' color='#6272a4'>Requer conexão à internet. Aprox. 1-2 GB de download.</span>" \
    --button="Instalar Gaming:0" \
    --button="Pular:1"

if [ $? -eq 0 ]; then
    open_terminal \
        "yay -S --noconfirm --needed steam proton-ge-custom mangohud gamemode \
         lib32-gamemode lutris wine-staging winetricks \
         lib32-mesa lib32-vulkan-icd-loader lib32-vulkan-radeon lib32-vulkan-nouveau \
         && echo 'Perfil de gaming instalado! Reinicie para aplicar as alterações.'"
fi

# ── Step 8: Popular apps ──────────────────────────────────────────────────────
SELECTION=$(yad --center --title="${TITLE} — Aplicativos" \
    --width=680 --height=540 \
    --list --checklist \
    --text="<b>Selecione os aplicativos que deseja instalar:</b>" \
    --column="✓" --column="Pacote" --column="Descrição" --column="Via" \
    FALSE "vlc"                    "Reprodutor de mídia universal"          "pacman"  \
    FALSE "libreoffice-fresh"      "Suite de escritório completa"           "pacman"  \
    FALSE "gimp"                   "Editor de imagens avançado"             "pacman"  \
    FALSE "obs-studio"             "Gravação e streaming de tela"           "pacman"  \
    FALSE "audacity"               "Editor de áudio"                        "pacman"  \
    FALSE "thunderbird"            "Cliente de e-mail"                      "pacman"  \
    FALSE "telegram-desktop"       "Mensagens instantâneas"                 "pacman"  \
    FALSE "visual-studio-code-bin" "VS Code — editor de código"             "AUR"     \
    FALSE "brave-bin"              "Browser focado em privacidade"          "AUR"     \
    FALSE "onlyoffice-bin"         "Suite Office compatível com MS Office"  "AUR"     \
    FALSE "discord"                "Chat, voz e comunidades"                "Flatpak" \
    FALSE "spotify"                "Streaming de música"                    "Flatpak" \
    FALSE "signal-desktop"         "Mensagens seguras"                      "Flatpak" \
    FALSE "bottles"                "Gerenciar prefixos Wine facilmente"     "Flatpak" \
    --button="Instalar Selecionados:0" \
    --button="Pular:1" \
    --separator="|" --print-column=2 2>/dev/null)

if [ $? -eq 0 ] && [ -n "${SELECTION}" ]; then
    PACMAN_PKGS=""
    AUR_PKGS=""
    FLATPAK_PKGS=""

    IFS='|' read -ra PKGS <<< "${SELECTION}"
    for pkg in "${PKGS[@]}"; do
        pkg="${pkg// /}"
        [ -z "${pkg}" ] && continue
        case "${pkg}" in
            "visual-studio-code-bin"|"brave-bin"|"onlyoffice-bin")
                AUR_PKGS="${AUR_PKGS} ${pkg}" ;;
            "discord")  FLATPAK_PKGS="${FLATPAK_PKGS} com.discordapp.Discord" ;;
            "spotify")  FLATPAK_PKGS="${FLATPAK_PKGS} com.spotify.Client" ;;
            "signal-desktop") FLATPAK_PKGS="${FLATPAK_PKGS} org.signal.Signal" ;;
            "bottles")  FLATPAK_PKGS="${FLATPAK_PKGS} com.usebottles.bottles" ;;
            *)          PACMAN_PKGS="${PACMAN_PKGS} ${pkg}" ;;
        esac
    done

    INSTALL_CMD=""
    [ -n "${PACMAN_PKGS}" ] && \
        INSTALL_CMD="${INSTALL_CMD}sudo pacman -S --noconfirm --needed ${PACMAN_PKGS}; "
    [ -n "${AUR_PKGS}" ] && \
        INSTALL_CMD="${INSTALL_CMD}yay -S --noconfirm --needed ${AUR_PKGS}; "
    [ -n "${FLATPAK_PKGS}" ] && \
        INSTALL_CMD="${INSTALL_CMD}flatpak install -y flathub ${FLATPAK_PKGS}; "

    [ -n "${INSTALL_CMD}" ] && open_terminal "${INSTALL_CMD}"
fi

# ── Step 9: Done ──────────────────────────────────────────────────────────────
yad --center --title="${TITLE}" \
    --width=520 --height=280 \
    --image="${ICON_OK}" \
    --text="<span size='large' weight='bold'>ClariceOS está pronto!</span>\n\n\
Seu sistema está configurado e pronto para uso.\n\n\
<span size='small'>Dicas rápidas:\n\
• <tt>yay -Syu</tt> — atualizar tudo (pacman + AUR)\n\
• <tt>flatpak update</tt> — atualizar apps Flatpak\n\
• <tt>snapper list</tt> — listar snapshots btrfs\n\n\
📖 Documentação: <tt>github.com/rrattes/ClariceOS</tt>\n\
🐛 Problemas: <tt>github.com/rrattes/ClariceOS/issues</tt></span>" \
    --button="Abrir GitHub:2" \
    --button="Fechar:0"

ret=$?
[ ${ret} -eq 2 ] && xdg-open "https://github.com/rrattes/ClariceOS" &

# Mark as done — won't show again
touch "${SENTINEL}"
