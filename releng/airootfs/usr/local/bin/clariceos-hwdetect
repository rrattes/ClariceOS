#!/usr/bin/env bash
# ClariceOS Hardware Detection
# Collects hardware info and writes a summary to /var/log/clariceos-hardware.log
# Called once after first boot by clariceos-hwdetect.service

set -euo pipefail

LOG="/var/log/clariceos-hardware.log"
DATE=$(date '+%Y-%m-%d %H:%M:%S')

{
echo "# ClariceOS Hardware Report — ${DATE}"
echo "# Generated by clariceos-hwdetect"
echo ""

# ── CPU ───────────────────────────────────────────────────────────────────────
echo "## CPU"
grep -m1 "model name" /proc/cpuinfo 2>/dev/null | sed 's/model name\s*:\s*//' || echo "unknown"
echo "  Cores: $(nproc)"
echo ""

# ── RAM ───────────────────────────────────────────────────────────────────────
echo "## RAM"
free -h | awk '/^Mem:/ { print "  Total: " $2 "  Available: " $7 }'
echo ""

# ── GPU ───────────────────────────────────────────────────────────────────────
echo "## GPU"
lspci 2>/dev/null | grep -i "vga\|3d\|display" || echo "  No GPU detected via lspci"
echo ""

# ── Storage ───────────────────────────────────────────────────────────────────
echo "## Storage"
lsblk -d -o NAME,SIZE,MODEL,TRAN 2>/dev/null | grep -v "^loop" || true
echo ""

# ── Network ───────────────────────────────────────────────────────────────────
echo "## Network"
lspci 2>/dev/null | grep -i "network\|ethernet\|wireless\|wi-fi\|wlan" || true
lsusb 2>/dev/null | grep -i "wireless\|wlan\|wi-fi\|realtek.*wifi\|mediatek\|broadcom" || true
echo ""

# ── Bluetooth ─────────────────────────────────────────────────────────────────
echo "## Bluetooth"
if rfkill list bluetooth 2>/dev/null | grep -q "bluetooth"; then
    echo "  Present (rfkill)"
elif lsusb 2>/dev/null | grep -qi "bluetooth"; then
    echo "  Present (USB)"
else
    echo "  Not detected"
fi
echo ""

# ── Audio ─────────────────────────────────────────────────────────────────────
echo "## Audio"
lspci 2>/dev/null | grep -i "audio\|sound" || echo "  No PCI audio card"
aplay -l 2>/dev/null | grep "^card" || echo "  No ALSA playback devices"
echo ""

# ── Input Devices ─────────────────────────────────────────────────────────────
echo "## Input"
lsusb 2>/dev/null | grep -i "keyboard\|mouse\|gamepad\|joystick\|controller" || true
echo ""

# ── Firmware / UEFI ───────────────────────────────────────────────────────────
echo "## Boot"
if [ -d /sys/firmware/efi ]; then
    echo "  Mode: UEFI"
    efibootmgr 2>/dev/null | grep "BootCurrent" || true
else
    echo "  Mode: Legacy BIOS"
fi
echo ""

# ── Recommendations ───────────────────────────────────────────────────────────
echo "## Recommendations"

# NVIDIA without driver
if lspci 2>/dev/null | grep -qi "NVIDIA" && ! pacman -Q nvidia-dkms &>/dev/null 2>&1; then
    echo "  [!] NVIDIA GPU found but nvidia-dkms is NOT installed."
    echo "      Run: yay -S nvidia-dkms nvidia-utils lib32-nvidia-utils"
fi

# AMD without vulkan
if lspci 2>/dev/null | grep -qi "AMD.*VGA\|VGA.*AMD" && ! pacman -Q vulkan-radeon &>/dev/null 2>&1; then
    echo "  [!] AMD GPU found but vulkan-radeon is NOT installed."
    echo "      Run: sudo pacman -S vulkan-radeon lib32-vulkan-radeon"
fi

# Bluetooth enabled but service off
if rfkill list bluetooth 2>/dev/null | grep -q "bluetooth"; then
    if ! systemctl is-enabled bluetooth &>/dev/null; then
        echo "  [!] Bluetooth hardware found but service is disabled."
        echo "      Run: sudo systemctl enable --now bluetooth"
    fi
fi

# Flathub not configured
if ! flatpak remotes 2>/dev/null | grep -q "flathub"; then
    echo "  [!] Flathub is not configured."
    echo "      Run: flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo"
fi

echo ""
echo "# End of report"
} > "${LOG}" 2>&1

chmod 644 "${LOG}"
echo "ClariceOS hardware report written to ${LOG}"
